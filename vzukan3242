do local Rayfield=loadstring(game:HttpGet("https://sirius.menu/rayfield"))();local Window=Rayfield:CreateWindow({Name="🐉Cut Grass for Brainrots🐉 Made by DC:8gzu",LoadingTitle="Lade...",LoadingSubtitle="Initialisiere...",ConfigurationSaving={Enabled=false}});local TMain=Window:CreateTab("Main","zap");local TBase=Window:CreateTab("Base","map-pin");local TMove=Window:CreateTab("Movement","person-standing");local lp=game.Players.LocalPlayer;local autoFarmActive=false;local cashDelay=5;local baseCF=nil;local function getRoot() return lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") ;end local function getHum() return lp.Character and lp.Character:FindFirstChildOfClass("Humanoid") ;end TMain:CreateSection("Auto Farm");TMain:CreateToggle({Name="Auto Collect Cash",CurrentValue=false,Callback=function(v) autoFarmActive=v;if v then task.spawn(function() while autoFarmActive do local hrp=getRoot();if hrp then for _,obj in pairs(workspace:GetDescendants()) do if ((obj.Name=="Active_part") and obj:IsA("BasePart")) then firetouchinterest(hrp,obj,0);task.wait(0.1);firetouchinterest(hrp,obj,1);end end end task.wait(cashDelay);end end);end end});TMain:CreateSlider({Name="Cash Delay (seconds)",Range={0.5,30},Increment=0.5,CurrentValue=5,Callback=function(v) cashDelay=v;end});TMain:CreateButton({Name="Delete Grass",Callback=function() local count=0;for _,obj in pairs(workspace:GetDescendants()) do if (string.find(obj.Name,"Grass_") or (obj.Name=="AntiJumpCollider")) then obj:Destroy();count+=1 end end Rayfield:Notify({Title="Erfolg",Content="Entfernt: "   .. count   .. " Objekte" });end});TBase:CreateButton({Name="Save Base Position",Callback=function() local root=getRoot();if root then baseCF=root.CFrame;end end});TBase:CreateButton({Name="Teleport to Base",Callback=function() if baseCF then local root=getRoot();if root then root.CFrame=baseCF;end end end});TMove:CreateSlider({Name="Walk Speed",Range={16,200},Increment=1,CurrentValue=48,Callback=function(v) local h=getHum();if h then h.WalkSpeed=v;end end});TMove:CreateSlider({Name="Jump Power",Range={50,500},Increment=1,CurrentValue=75,Callback=function(v) local h=getHum();if h then h.JumpPower=v;end end});local VirtualUser=game:GetService("VirtualUser");lp.Idled:Connect(function() VirtualUser:Button2Down(Vector2.new(0,0),workspace.CurrentCamera.CFrame);task.wait(1);VirtualUser:Button2Up(Vector2.new(0,0),workspace.CurrentCamera.CFrame);end);TMain:CreateToggle({Name="Auto-Collect Items",CurrentValue=false,Callback=function(v) _G.AutoCollect=v;task.spawn(function() while _G.AutoCollect do for _,obj in pairs(workspace:GetDescendants()) do if (obj:IsA("TouchTransmitter") and obj.Parent:IsA("BasePart")) then firetouchinterest(getRoot(),obj.Parent,0);firetouchinterest(getRoot(),obj.Parent,1);end end task.wait(1);end end);end});TMain:CreateToggle({Name="Fullbright",CurrentValue=false,Callback=function(v) if v then game.Lighting.Brightness=2;game.Lighting.ClockTime=14;game.Lighting.FogEnd=99999;else game.Lighting.Brightness=1;game.Lighting.ClockTime=12;end end});TMove:CreateToggle({Name="Infinite Jump",CurrentValue=false,Callback=function(v) _G.InfJump=v;end});game:GetService("UserInputService").JumpRequest:Connect(function() if _G.InfJump then local hum=getHum();if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping);end end end);local noclipActive=false;game:GetService("RunService").Stepped:Connect(function() if noclipActive then local char=lp.Character;if char then for _,v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide=false;end end end end end);TMove:CreateToggle({Name="Noclip",CurrentValue=false,Callback=function(v) noclipActive=v;if  not noclipActive then local char=lp.Character;if char then for _,v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide=true;end end end end end});local TBrainrot=Window:CreateTab("Brainrots","target");TBrainrot:CreateSection("Status: Development");TBrainrot:CreateLabel("Auto-Farm features are coming soon!");TBrainrot:CreateToggle({Name="Auto Rebirth",CurrentValue=false,Callback=function(v) autoRebirthActive=v;if v then task.spawn(function() while autoRebirthActive do local foundEvent=nil;for _,obj in pairs(game:GetService("ReplicatedStorage"):GetDescendants()) do if (obj:IsA("RemoteEvent") and (obj.Name=="RebirthButtonClicked")) then foundEvent=obj;break;end end if foundEvent then foundEvent:FireServer();else warn("Event 'RebirthButtonClicked' konnte nicht gefunden werden!");end task.wait(2);end end);end end});local TStuff=Window:CreateTab("Auto Stuff","shopping-cart");TStuff:CreateSection("Auto Upgrades (Knit Bypass)");local function buyUpgradeKnit(serviceName,upgradeType) local Knit=debug.getupvalue(require(game:GetService("ReplicatedStorage").Packages.Knit).Start,1);local Service=Knit.GetService(serviceName);if Service then if Service.Purchase then Service.Purchase(Service,upgradeType);elseif Service.Buy then Service.Buy(Service,upgradeType);end end end TStuff:CreateButton({Name="Buy Speed (Test)",Callback=function() buyUpgradeKnit("UpgradesService","Speed");end}); end
